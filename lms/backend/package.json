    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "redis": "^4.6.12",
    "stripe": "^14.7.0",
    "nodemailer": "^6.9.7",
    "sendgrid": "^5.2.12",
    "axios": "^1.6.2",
    "zod": "^3.22.4",
    "uuid": "^9.0.1",
    "pdfkit": "^0.13.0",
    "qrcode": "^1.5.3",
    "winston": "^3.11.0",
    "joi": "^17.11.0"
